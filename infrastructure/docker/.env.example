# Facturance local development infrastructure

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=facturance
POSTGRES_PASSWORD=facturance
POSTGRES_DB=facturance_platform
DATABASE_URL=postgresql://facturance:facturance@localhost:5432/facturance_platform?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Mailpit
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_HOST=localhost
MAILPIT_SMTP_PORT=1025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
